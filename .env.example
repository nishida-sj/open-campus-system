# =====================================================
# 必須: Supabase接続
# =====================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =====================================================
# 必須: アプリケーション
# =====================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =====================================================
# フォールバック: LINE連携（テナントDBに設定がない場合に使用）
# ※ マルチテナント環境ではテナント設定画面から設定を推奨
# =====================================================
LINE_CHANNEL_ACCESS_TOKEN=your-channel-access-token
LINE_CHANNEL_SECRET=your-channel-secret

# =====================================================
# フォールバック: OpenAI API（テナントDBに設定がない場合に使用）
# ※ マルチテナント環境ではテナント設定画面から設定を推奨
# =====================================================
OPENAI_API_KEY=your-openai-api-key

# =====================================================
# 廃止予定（マルチテナント移行により不要）
# ※ DB tenantsテーブルに移行済み
# =====================================================
# NEXT_PUBLIC_LINE_BOT_BASIC_ID=@your-bot-id  → tenants.line_bot_basic_id
# LINE_BOT_BASIC_ID=@your-bot-id              → tenants.line_bot_basic_id
# NEXT_PUBLIC_ADMIN_PASSWORD=your-password     → Supabase Auth
# TOKEN_SECRET=your-secret                    → Supabase Auth
# OPENAI_MODEL=gpt-4o-mini                   → ai_settings.model
# OPENAI_MAX_TOKENS=500                      → ai_settings.max_tokens
# OPENAI_TEMPERATURE=0.7                     → ai_settings.temperature
